{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"composite": true,
		"tsBuildInfoFile": "./node_modules/.tmp/tsconfig.testserver.tsbuildinfo",
		"skipLibCheck": true,
		"noEmit": true,
		"module": "ESNext",
		"target": "ESNext",
		"moduleResolution": "bundler",
		"resolveJsonModule": true,
		"strict": true,
		"baseUrl": ".",
		"paths": {
			"@/*": ["./src/*"],
			"@data/*": ["./testserver/data/*"]
		}
	},
	"include": ["testserver/src/**/*.ts", "src/**/*.ts"]
}

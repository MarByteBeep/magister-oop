{
	"compilerOptions": {
		"resolveJsonModule": true,
		"esModuleInterop": true,
		"module": "ESNext",
		"target": "ESNext",
		"moduleResolution": "Node",
		"baseUrl": ".",
		"paths": {
			"@/*": ["../src/*"]
		},
		"strict": true,
		"forceConsistentCasingInFileNames": true
	},
	"include": ["./**/*.ts", "../src/**/*"]
}
